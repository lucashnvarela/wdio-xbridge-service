{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": [
      "ES2020"
    ],
    "outDir": "./build",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "@wdio/globals/types",
    ],
  },
  "include": [
    "./src/**/*",
  ],
  "exclude": [
    "./node_modules/**",
    "./build/**/*"
  ]
}