{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "node",
		"lib": ["ES2020"],
		"outDir": "./build",
		"strict": true,
		"esModuleInterop": true,
		"declaration": true,
		"skipLibCheck": true,
		"types": ["node", "@wdio/globals/types"]
	},
	"include": ["./src/**/*"],
	"exclude": ["./node_modules/**", "./build/**/*"]
}
